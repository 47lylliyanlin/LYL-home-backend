# Active AI profile. Change this one line to switch routing.
# Options below: CLAUDE, GPT, GEMINI, GLM, or any custom profile name you add.
AI_ACTIVE_PROFILE=CLAUDE

# Claude official or Anthropic-compatible proxy.
AI_CLAUDE_PROVIDER=anthropic
AI_CLAUDE_API_KEY=your_claude_or_proxy_key_here
AI_CLAUDE_BASE_URL=https://api.anthropic.com
AI_CLAUDE_MODEL=claude-opus-4-6

# GPT / OpenAI-compatible API.
AI_GPT_PROVIDER=openai
AI_GPT_API_KEY=your_openai_or_proxy_key_here
AI_GPT_BASE_URL=https://api.openai.com/v1
AI_GPT_MODEL=gpt-4.1

# Gemini official native API.
AI_GEMINI_PROVIDER=gemini_native
AI_GEMINI_API_KEY=your_google_gemini_api_key_here
AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_GEMINI_MODEL=gemini-2.5-pro

# Gemini through an OpenAI-compatible proxy, if you prefer relay mode.
# AI_GEMINI_PROVIDER=openai_compatible
# AI_GEMINI_API_KEY=your_gemini_proxy_key_here
# AI_GEMINI_BASE_URL=https://your-gemini-proxy.example.com/v1
# AI_GEMINI_MODEL=gemini-2.5-pro

# GLM through BigModel Anthropic-compatible API.
AI_GLM_PROVIDER=anthropic
AI_GLM_API_KEY=your_bigmodel_key_here
AI_GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
AI_GLM_MODEL=glm-4.6v
# Backward-compatible fallback names. These can be omitted if profile vars are set.
ANTHROPIC_API_KEY=your_anthropic_or_proxy_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-opus-4-6
OPENAI_API_KEY=your_openai_or_proxy_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ElevenLabs voice tuning, optional
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.0
ELEVENLABS_USE_SPEAKER_BOOST=true
